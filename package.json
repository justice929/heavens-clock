{
  "name": "heavens-clock",
  "version": "1.0.0",
  "description": "Memento Mori life countdown clock",
  "scripts": {
    "prepare:web": "node scripts/prepare-web.js",
    "web": "npm run prepare:web && npx --yes serve www -l 4173",
    "build:billing": "node scripts/build-billing.js",
    "cap:init": "npx cap init \"Heaven's Clock\" com.heavensclock.app --web-dir www",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run prepare:web && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "capacitor-plugin-cdv-purchase": "^13.15.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "esbuild": "^0.28.0"
  }
}
